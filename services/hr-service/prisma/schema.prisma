generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Configuration {
  id                Int       @id @default(autoincrement())
  nomEntreprise     String?
  sigle             String?
  numeroCc          String?
  numeroCnps        String?
  adresseSiege      String?
  telephone         String?
  email             String?
  tauxCnpsSalarial  Decimal?  @db.Decimal(12, 4)
  tauxCnpsPatronal  Decimal?  @db.Decimal(12, 4)
  tauxIs            Decimal?  @db.Decimal(12, 4)
  tauxCn            Decimal?  @db.Decimal(12, 4)
  tauxFdfpApprentis Decimal?  @db.Decimal(12, 4)
  tauxFdfpContinu   Decimal?  @db.Decimal(12, 4)
  smig              Decimal?  @db.Decimal(12, 2)
  plafondCnps       Decimal?  @db.Decimal(12, 2)
  baremesIgr        Json?
  dateMiseAJour     DateTime? @default(now())
}

model Employe {
  id                    String   @id @default(uuid())
  matricule             String   @unique
  civilite              String?
  nom                   String?
  prenoms               String?
  nomComplet            String?
  sexe                  String?
  dateNaissance         DateTime?
  lieuNaissance         String?
  nationalite           String?
  codeNationalite       String?
  situationMatrimoniale String?
  nombreEnfants         Int?
  nombrePartsIgr        Decimal? @db.Decimal(5, 2)
  adressePersonnelle    String?
  telephonePersonnel    String?
  emailPersonnel        String?
  lieuHabitation        String?
  naturePieceIdentite   String?
  numeroPieceIdentite   String?
  numeroCnps            String?
  nonSoumisCnps         Boolean?
  modePaiement          String?
  rib                   String?
  banque                String?
  statut                String?
  dateCreation          DateTime? @default(now())
  dateModification      DateTime? @updatedAt

  contrats             Contrat[]
  historiques          HistoriqueEmploye[]
  variablesMensuelles  VariablesMensuelle[]
  bulletins            BulletinPaie[]
  cumuls               CumulAnnuel[]
  conges               GestionConge[]
  provisionsConges     ProvisionCongeCalc[]
  absences             Absence[]
  prets                PretAvance[]
  ruptures             RuptureContrat[]
  gratifications       Gratification[]
  indemnitesRupture    IndemniteRupture[]
  declarationsCnps     DeclarationCnps[]
  declarationsFiscales DeclarationFiscale[]
  disas                Disa[]
  dascs                Dasc[]
  etat301s             Etat301[]
  provisionsRetraite   ProvisionRetraiteCalc[]
  detailsVirements     DetailVirement[]
  certificatsTravail   CertificatTravail[]
  evaluationsRecues    Evaluation[] @relation("EmployeEvaluations")
  evaluationsDonnees   Evaluation[] @relation("EvaluateurEvaluations")
}

model Contrat {
  id                        Int      @id @default(autoincrement())
  matricule                 String
  typeContrat               String?
  dateSignature             DateTime?
  dateDebut                 DateTime?
  dateFinPrevue             DateTime?
  dateFinReelle             DateTime?
  posteOccupe               String?
  direction                 String?
  service                   String?
  categorieProfessionnelle  String?
  echelon                   Int?
  regime                    String?
  typeEmploi                String?
  salaireBaseMensuel        Decimal? @db.Decimal(12, 2)
  periodeEssaiMois          Int?
  dureeCddMois              Int?
  motifRecrutement          String?
  lieuTravail               String?
  statutContrat             String?
  dateCreation              DateTime? @default(now())

  employe  Employe @relation(fields: [matricule], references: [matricule])
  ruptures RuptureContrat[]
}

model HistoriqueEmploye {
  id             Int      @id @default(autoincrement())
  matricule      String
  dateEvenement  DateTime?
  typeMouvement  String?
  ancienPoste    String?
  nouveauPoste   String?
  ancienSalaire  Decimal? @db.Decimal(12, 2)
  nouveauSalaire Decimal? @db.Decimal(12, 2)
  motif          String?
  observations   String?

  employe Employe @relation(fields: [matricule], references: [matricule])
}

model VariablesMensuelle {
  id                      Int      @id @default(autoincrement())
  matricule               String
  periode                 String?
  heuresSupp15            Decimal? @db.Decimal(8, 2)
  heuresSupp50            Decimal? @db.Decimal(8, 2)
  heuresSupp75            Decimal? @db.Decimal(8, 2)
  heuresSupp100           Decimal? @db.Decimal(8, 2)
  primeRendement          Decimal? @db.Decimal(12, 2)
  primeTransport          Decimal? @db.Decimal(12, 2)
  primeSalissure          Decimal? @db.Decimal(12, 2)
  primeAnciennete         Decimal? @db.Decimal(12, 2)
  primesDiverses          Decimal? @db.Decimal(12, 2)
  gratificationMensuelle  Decimal? @db.Decimal(12, 2)
  indemniteLogement       Decimal? @db.Decimal(12, 2)
  indemniteRepas          Decimal? @db.Decimal(12, 2)
  joursAbsenceInjustifiee Int?
  joursCongesPris         Int?
  joursMaladie            Int?
  joursMaternite          Int?
  retenuePret             Decimal? @db.Decimal(12, 2)
  retenueAutre            Decimal? @db.Decimal(12, 2)
  dateSaisie              DateTime? @default(now())
  statut                  String?

  employe  Employe @relation(fields: [matricule], references: [matricule])
  bulletins BulletinPaie[]
}

model BulletinPaie {
  id                      Int      @id @default(autoincrement())
  matricule               String
  periode                 String?
  salaireBase             Decimal? @db.Decimal(12, 2)
  heuresSuppMontant       Decimal? @db.Decimal(12, 2)
  primesTotal             Decimal? @db.Decimal(12, 2)
  salaireBrut             Decimal? @db.Decimal(12, 2)
  cotisationCnpsSalariale Decimal? @db.Decimal(12, 2)
  cotisationCnpsPatronale Decimal? @db.Decimal(12, 2)
  impotIs                 Decimal? @db.Decimal(12, 2)
  impotCn                 Decimal? @db.Decimal(12, 2)
  impotIgr                Decimal? @db.Decimal(12, 2)
  totalRetenues           Decimal? @db.Decimal(12, 2)
  salaireNet              Decimal? @db.Decimal(12, 2)
  coutTotalEmployeur      Decimal? @db.Decimal(12, 2)
  statutPaiement          String?
  datePaiement            DateTime?
  referenceVirement       String?
  dateGeneration          DateTime? @default(now())

  employe              Employe             @relation(fields: [matricule], references: [matricule])
  variablesMensuelleId Int?
  variablesMensuelle   VariablesMensuelle? @relation(fields: [variablesMensuelleId], references: [id])
  ecritures            EcritureComptable[]
}

model CumulAnnuel {
  id                   Int      @id @default(autoincrement())
  matricule            String
  annee                Int?
  cumulBrut            Decimal? @db.Decimal(12, 2)
  cumulNet             Decimal? @db.Decimal(12, 2)
  cumulCnps            Decimal? @db.Decimal(12, 2)
  cumulImpots          Decimal? @db.Decimal(12, 2)
  cumulCongesAcquis    Int?
  cumulCongesConsommes Int?
  cumulHeuresSupp      Decimal? @db.Decimal(12, 2)

  employe Employe @relation(fields: [matricule], references: [matricule])
}

model GestionConge {
  id                   Int      @id @default(autoincrement())
  matricule            String
  dateDebut            DateTime?
  dateFin              DateTime?
  typeConge            String?
  nombreJours          Int?
  allocationCongePayee Decimal? @db.Decimal(12, 2)
  statut               String?
  dateDemande          DateTime?
  dateApprobation      DateTime?
  observations         String?

  employe Employe @relation(fields: [matricule], references: [matricule])
}

model ProvisionCongeCalc {
  id                   Int      @id @default(autoincrement())
  matricule            String
  periode              String?
  droitCongeAcquisMois Decimal? @db.Decimal(6, 2)
  droitCongeCumule     Decimal? @db.Decimal(6, 2)
  droitCongeConsomme   Decimal? @db.Decimal(6, 2)
  droitCongeRestant    Decimal? @db.Decimal(6, 2)
  montantProvision     Decimal? @db.Decimal(12, 2)
  tauxJournalier       Decimal? @db.Decimal(12, 2)

  employe Employe @relation(fields: [matricule], references: [matricule])
}

model Absence {
  id             Int      @id @default(autoincrement())
  matricule      String
  dateAbsence    DateTime?
  typeAbsence    String?
  nombreJours    Int?
  justification  String?
  retenueSalaire Decimal? @db.Decimal(12, 2)

  employe Employe @relation(fields: [matricule], references: [matricule])
}

model PretAvance {
  id                     Int      @id @default(autoincrement())
  matricule              String
  datePret               DateTime?
  montantTotalPrete      Decimal? @db.Decimal(12, 2)
  montantRestantDu       Decimal? @db.Decimal(12, 2)
  nombreMoisRemboursement Int?
  mensualiteRetenue      Decimal? @db.Decimal(12, 2)
  dateDebutRemboursement DateTime?
  dateFinRemboursement   DateTime?
  nombreMoisPayes        Int?
  statut                 String?
  motifPret              String?

  employe Employe @relation(fields: [matricule], references: [matricule])
}

model RuptureContrat {
  id                    Int      @id @default(autoincrement())
  contratId             Int
  matricule             String
  dateRupture           DateTime?
  motifRupture          String?
  indemnitePreavis      Decimal? @db.Decimal(12, 2)
  indemniteLicenciement Decimal? @db.Decimal(12, 2)
  indemniteCongesPayes  Decimal? @db.Decimal(12, 2)
  indemniteFinCarriere  Decimal? @db.Decimal(12, 2)
  montantTotalDu        Decimal? @db.Decimal(12, 2)
  dateRemiseCertificat  DateTime?
  observations          String?

  contrat     Contrat        @relation(fields: [contratId], references: [id])
  employe     Employe        @relation(fields: [matricule], references: [matricule])
  certificats CertificatTravail[]
  indemnites  IndemniteRupture[]
}

model CertificatTravail {
  id                Int      @id @default(autoincrement())
  ruptureId         Int
  matricule         String
  dateEntree        DateTime?
  dateSortie        DateTime?
  postesOccupes     String?
  dateEmission      DateTime?
  signatureAutorite String?

  rupture RuptureContrat @relation(fields: [ruptureId], references: [id])
  employe Employe       @relation(fields: [matricule], references: [matricule])
}

model Gratification {
  id                Int      @id @default(autoincrement())
  matricule         String
  periode           String?
  typeGratification String?
  baseCalcul        Decimal? @db.Decimal(12, 2)
  tauxGratification Decimal? @db.Decimal(6, 2)
  montantBrut       Decimal? @db.Decimal(12, 2)
  retenues          Decimal? @db.Decimal(12, 2)
  montantNet        Decimal? @db.Decimal(12, 2)
  dateVersement     DateTime?

  employe Employe @relation(fields: [matricule], references: [matricule])
}

model IndemniteRupture {
  id                           Int      @id @default(autoincrement())
  ruptureId                    Int
  matricule                    String
  indemnitePreavisMontant      Decimal? @db.Decimal(12, 2)
  indemnitePreavisJours        Int?
  indemniteLicenciementMontant Decimal? @db.Decimal(12, 2)
  indemniteLicenciementMois    Int?
  indemniteCongesJours         Int?
  indemniteCongesMontant       Decimal? @db.Decimal(12, 2)
  totalIndemnites              Decimal? @db.Decimal(12, 2)

  rupture RuptureContrat @relation(fields: [ruptureId], references: [id])
  employe Employe       @relation(fields: [matricule], references: [matricule])
}

model DeclarationCnps {
  id                Int      @id @default(autoincrement())
  periode           String?
  typeDeclaration   String?
  matricule         String
  salaireSoumisCnps Decimal? @db.Decimal(12, 2)
  partSalariale     Decimal? @db.Decimal(12, 2)
  partPatronale     Decimal? @db.Decimal(12, 2)
  totalCotisation   Decimal? @db.Decimal(12, 2)
  dateEnvoi         DateTime?
  statutDeclaration String?

  employe Employe @relation(fields: [matricule], references: [matricule])
}

model DeclarationFiscale {
  id               Int      @id @default(autoincrement())
  periode          String?
  typeDeclaration  String?
  matricule        String
  salaireImposable Decimal? @db.Decimal(12, 2)
  montantIs        Decimal? @db.Decimal(12, 2)
  montantCn        Decimal? @db.Decimal(12, 2)
  montantIgr       Decimal? @db.Decimal(12, 2)
  totalImpots      Decimal? @db.Decimal(12, 2)
  dateDeclaration  DateTime?
  statut           String?

  employe Employe @relation(fields: [matricule], references: [matricule])
}

model Disa {
  id                   Int      @id @default(autoincrement())
  annee                Int?
  matricule            String
  nombreMoisPresence   Int?
  salaireAnnuel        Decimal? @db.Decimal(12, 2)
  cotisationsAnnuelles Decimal? @db.Decimal(12, 2)
  impotsAnnuels        Decimal? @db.Decimal(12, 2)
  dateDeclaration      DateTime?

  employe Employe @relation(fields: [matricule], references: [matricule])
}

model Dasc {
  id                     Int      @id @default(autoincrement())
  annee                  Int?
  matricule              String
  accidentsTravail       Int?
  prestationsFamiliales  Decimal? @db.Decimal(12, 2)
  indemnitesJournalieres Decimal? @db.Decimal(12, 2)
  dateDeclaration        DateTime?

  employe Employe @relation(fields: [matricule], references: [matricule])
}

model Etat301 {
  id              Int      @id @default(autoincrement())
  annee           Int?
  matricule       String
  salaireAnnuel   Decimal? @db.Decimal(12, 2)
  impotAnnuel     Decimal? @db.Decimal(12, 2)
  regularisation  Decimal? @db.Decimal(12, 2)
  dateDeclaration DateTime?

  employe Employe @relation(fields: [matricule], references: [matricule])
}

model EcritureComptable {
  id               Int      @id @default(autoincrement())
  dateEcriture     DateTime?
  periode          String?
  compteDebit      String?
  compteCredit     String?
  libelleOperation String?
  montant          Decimal? @db.Decimal(12, 2)
  journal          String?
  referencePiece   String?
  statut           String?

  bulletinId Int?
  bulletin   BulletinPaie? @relation(fields: [bulletinId], references: [id])
}

model ProvisionRetraiteCalc {
  id                          Int      @id @default(autoincrement())
  matricule                   String
  periode                     String?
  indemniteFinCarriereEstimee Decimal? @db.Decimal(12, 2)
  provisionCumulee            Decimal? @db.Decimal(12, 2)
  tauxProvision               Decimal? @db.Decimal(6, 2)
  dateCalcul                  DateTime? @default(now())

  employe Employe @relation(fields: [matricule], references: [matricule])
}

model LivrePaieMensuel {
  id                           Int      @id @default(autoincrement())
  periode                      String?
  nombreEmployes               Int?
  totalSalaireBrut             Decimal? @db.Decimal(12, 2)
  totalCotisationCnpsSalariale Decimal? @db.Decimal(12, 2)
  totalCotisationCnpsPatronale Decimal? @db.Decimal(12, 2)
  totalImpotsIs                Decimal? @db.Decimal(12, 2)
  totalImpotsCn                Decimal? @db.Decimal(12, 2)
  totalImpotsIgr               Decimal? @db.Decimal(12, 2)
  totalRetenues                Decimal? @db.Decimal(12, 2)
  totalSalaireNet              Decimal? @db.Decimal(12, 2)
  totalChargesPatronales       Decimal? @db.Decimal(12, 2)
  coutTotalEmployeur           Decimal? @db.Decimal(12, 2)
  dateGeneration               DateTime? @default(now())
}

model LivrePaieAnnuel {
  id                             Int      @id @default(autoincrement())
  annee                          Int?
  nombreEmployesMoyen            Decimal? @db.Decimal(6, 1)
  totalGainsAnnuels              Decimal? @db.Decimal(12, 2)
  totalChargesPatronalesAnnuelles Decimal? @db.Decimal(12, 2)
  coutTotalAnnuel                Decimal? @db.Decimal(12, 2)
  masseSalarialeMoyenne          Decimal? @db.Decimal(12, 2)
}

model OrdreBancaire {
  id                  Int      @id @default(autoincrement())
  periode             String?
  dateVirement        DateTime?
  banqueEmetteur      String?
  nombreBeneficiaires Int?
  montantTotalLot     Decimal? @db.Decimal(12, 2)
  statut              String?
  referenceVirement   String?

  details DetailVirement[]
}

model DetailVirement {
  id              Int      @id @default(autoincrement())
  ordreId         Int
  matricule       String
  ribBeneficiaire String?
  montantNet      Decimal? @db.Decimal(12, 2)
  dateExecution   DateTime?

  ordre   OrdreBancaire @relation(fields: [ordreId], references: [id])
  employe Employe       @relation(fields: [matricule], references: [matricule])
}

model StatistiqueRh {
  id                   Int      @id @default(autoincrement())
  periode              String?
  effectifDebutPeriode Int?
  effectifFinPeriode   Int?
  effectifMoyen        Decimal? @db.Decimal(6, 1)
  embauches            Int?
  departs              Int?
  tauxAbsenteisme      Decimal? @db.Decimal(6, 2)
  tauxTurnover         Decimal? @db.Decimal(6, 2)
  ancienneteMoyenne    Decimal? @db.Decimal(6, 1)
  masseSalarialeTotale Decimal? @db.Decimal(12, 2)
  coutMoyenEmploye     Decimal? @db.Decimal(12, 2)
  coutChargesSociales  Decimal? @db.Decimal(12, 2)
}

model Evaluation {
  id             String   @id @default(uuid())
  employeId      String
  evaluateurId   String
  dateEvaluation DateTime
  periode        String
  noteGlobale    Decimal  @db.Decimal(3, 2)
  competences    Json
  commentaires   String?
  objectifs      Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  employe    Employe @relation("EmployeEvaluations", fields: [employeId], references: [id], onDelete: Cascade)
  evaluateur Employe @relation("EvaluateurEvaluations", fields: [evaluateurId], references: [id])

  @@map("evaluations")
}

// ============================================================
// SIRH PHASE 2/3 - Portail Employé, Recrutement, Formation
// ============================================================

// Comptes utilisateurs du portail employé
model UserAccount {
  id          String   @id @default(uuid())
  matricule   String   @unique
  email       String   @unique
  password    String
  role        String   @default("EMPLOYE") // EMPLOYE | RH_MANAGER | RH_ADMIN
  isActive    Boolean  @default(true)
  lastLogin   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  demandesConge   DemandeConge[]
  demandesPret    DemandePret[]
  notifications   Notification[]
}

// Demandes de congé via portail (workflow d'approbation)
model DemandeConge {
  id             Int      @id @default(autoincrement())
  userId         String
  matricule      String
  typeConge      String   // Annuel, Maladie, Maternité, Exceptionnel
  dateDebut      DateTime
  dateFin        DateTime
  nombreJours    Int
  motif          String?
  statut         String   @default("En attente") // En attente | Approuvé | Refusé
  approbateurId  String?
  dateDecision   DateTime?
  commentaire    String?
  createdAt      DateTime @default(now())

  user           UserAccount @relation(fields: [userId], references: [id])
}

// Demandes de prêts via portail
model DemandePret {
  id              Int      @id @default(autoincrement())
  userId          String
  matricule       String
  typePret        String   // Personnel, Scolarité, Médical, Logement
  montantDemande  Decimal  @db.Decimal(12, 2)
  dureeRemboursement Int
  motif           String?
  statut          String   @default("En attente")
  approbateurId   String?
  dateDecision    DateTime?
  commentaire     String?
  createdAt       DateTime @default(now())

  user            UserAccount @relation(fields: [userId], references: [id])
}

// Notifications système
model Notification {
  id         Int      @id @default(autoincrement())
  userId     String
  titre      String
  message    String
  type       String   @default("INFO") // INFO | SUCCESS | WARNING | URGENT
  isRead     Boolean  @default(false)
  lien       String?
  createdAt  DateTime @default(now())

  user       UserAccount @relation(fields: [userId], references: [id])
}

// ---- RECRUTEMENT ----

model OffreEmploi {
  id               Int      @id @default(autoincrement())
  intitulePoste    String
  direction        String?
  typeContrat      String?  // CDI, CDD, Stage, Intérim
  profil           String?  // Description du profil recherché
  missions         String?
  salaireFourchette String?
  dateOuverture    DateTime @default(now())
  dateLimiteCandidature DateTime?
  statut           String   @default("Ouverte") // Ouverte | Fermée | Pourvue
  createdAt        DateTime @default(now())

  candidatures     Candidature[]
}

model Candidature {
  id              Int      @id @default(autoincrement())
  offreId         Int
  nomCandidat     String
  prenomCandidat  String
  email           String
  telephone       String?
  cvUrl           String?  // Chemin vers le CV uploadé
  lettreMotivation String?
  source          String?  // LinkedIn, Site Web, Interne, Recommandation
  statut          String   @default("Reçue") // Reçue | Présélection | Entretien | Offre | Intégré | Refusé
  noteEvaluation  Int?     // Score 1-10
  commentaires    String?
  dateEntretien   DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  offre           OffreEmploi @relation(fields: [offreId], references: [id])
  entretiens      Entretien[]
}

model Entretien {
  id              Int      @id @default(autoincrement())
  candidatureId   Int
  dateHeure       DateTime
  type            String?  // RH, Technique, DG
  intervieweurs   String?
  lieu            String?
  statut          String   @default("Planifié") // Planifié | Réalisé | Annulé
  noteCandidat    Int?
  remarques       String?
  createdAt       DateTime @default(now())

  candidature     Candidature @relation(fields: [candidatureId], references: [id])
}

// ---- FORMATION ----

model PlanFormation {
  id          Int      @id @default(autoincrement())
  annee       Int
  budget      Decimal  @db.Decimal(12, 2)
  statut      String   @default("Draft") // Draft | Validé | Clôturé
  createdAt   DateTime @default(now())

  formations  Formation[]
}

model Formation {
  id              Int      @id @default(autoincrement())
  planId          Int?
  titre           String
  type            String?  // Présentiel | En ligne | Mixte
  organisme       String?
  objectifs       String?
  dureeHeures     Decimal? @db.Decimal(6, 1)
  cout            Decimal? @db.Decimal(12, 2)
  dateDebut       DateTime?
  dateFin         DateTime?
  lieu            String?
  capaciteMax     Int?
  statut          String   @default("Planifiée") // Planifiée | En cours | Terminée | Annulée
  createdAt       DateTime @default(now())

  plan            PlanFormation? @relation(fields: [planId], references: [id])
  inscriptions    InscriptionFormation[]
}

model InscriptionFormation {
  id              Int      @id @default(autoincrement())
  formationId     Int
  matricule       String
  statut          String   @default("Inscrit") // Inscrit | Présent | Absent | Certifié
  noteAvant       Int?     // Évaluation avant formation (test)
  noteApres       Int?     // Évaluation après formation
  noteFormation   Int?     // Note donnée à la formation (satisfaction)
  commentaire     String?
  attestationUrl  String?
  dateInscription DateTime @default(now())

  formation       Formation @relation(fields: [formationId], references: [id])
}

// ---- CARRIÈRES & COMPÉTENCES ----

model Competence {
  id       Int    @id @default(autoincrement())
  code     String @unique
  libelle  String
  famille  String?   // Technique, Managériale, Transversale

  employeCompetences EmployeCompetence[]
}

model EmployeCompetence {
  id              Int      @id @default(autoincrement())
  matricule       String
  competenceId    Int
  niveau          Int      // 1=Notions, 2=Pratique, 3=Maîtrise, 4=Expert
  dateAcquisition DateTime?
  certificat      String?

  competence      Competence @relation(fields: [competenceId], references: [id])
}

model PosteReferentiel {
  id           Int    @id @default(autoincrement())
  code         String @unique
  libelle      String
  familleEmploi String?
  grilleSalaire String?
  echelonMin   Int?
  echelonMax   Int?
}
