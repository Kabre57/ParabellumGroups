// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StatusFournisseur {
  ACTIF
  INACTIF
  BLOQUE
}

enum StatusDemandeAchat {
  BROUILLON
  SOUMISE
  APPROUVEE
  REJETEE
  PROFORMAS_EN_COURS
  PROFORMA_SOUMISE
  PROFORMA_APPROUVEE
  COMMANDEE
}

enum StatusBonCommande {
  BROUILLON
  ENVOYE
  CONFIRME
  LIVRE
  ANNULE
}

enum StatusProforma {
  BROUILLON
  SOUMISE
  APPROUVEE
  REJETEE
}

model Fournisseur {
  id                String             @id @default(uuid())
  nom               String
  email             String             @unique
  telephone         String?
  adresse           String?
  categorieActivite String?
  status            StatusFournisseur  @default(ACTIF)
  rating            Float?             @db.DoublePrecision
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  
  demandesAchat     DemandeAchat[]
  bonsCommande      BonCommande[]
  proformas         Proforma[]

  @@map("fournisseurs")
}

model DemandeAchat {
  id                    String                    @id @default(uuid())
  numeroDemande         String                    @unique
  titre                 String
  description           String?
  demandeurId           String
  demandeurEmail        String?
  enterpriseId          Int?
  enterpriseName        String?
  serviceId             Int?
  serviceName           String?
  fournisseurId         String?
  fournisseurNomLibre   String?
  objet                 String?
  devise                String                    @default("XOF")
  dateDemande           DateTime                  @default(now())
  dateBesoin            DateTime?
  montantEstime         Decimal?                  @db.Decimal(12, 2)
  montantHT             Decimal                   @default(0) @db.Decimal(12, 2)
  montantTVA            Decimal                   @default(0) @db.Decimal(12, 2)
  montantTTC            Decimal                   @default(0) @db.Decimal(12, 2)
  status                StatusDemandeAchat        @default(BROUILLON)
  notes                 String?
  submittedAt           DateTime?
  approvedAt            DateTime?
  approvedByUserId      String?
  approvedByServiceId   Int?
  approvedByServiceName String?
  rejectionReason       String?
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt
  
  fournisseur           Fournisseur?              @relation(fields: [fournisseurId], references: [id], onDelete: SetNull)
  bonsCommande          BonCommande[]
  lignes                LigneDemandeAchat[]
  approvalLogs          DemandeAchatApprovalLog[]
  proformas             Proforma[]

  @@map("demandes_achat")
  @@index([enterpriseId])
}

model BonCommande {
  id              String             @id @default(uuid())
  numeroBon       String             @unique
  demandeAchatId  String?
  proformaId      String?            @unique
  fournisseurId   String
  enterpriseId    Int?
  enterpriseName  String?
  serviceId       Int?
  serviceName     String?
  dateCommande    DateTime           @default(now())
  dateLivraison   DateTime?
  montantHT       Decimal            @default(0) @db.Decimal(12, 2)
  montantTVA      Decimal            @default(0) @db.Decimal(12, 2)
  montantTotal    Decimal            @db.Decimal(12, 2)
  status          StatusBonCommande  @default(BROUILLON)
  createdFromApproval Boolean        @default(false)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  
  demandeAchat    DemandeAchat?      @relation(fields: [demandeAchatId], references: [id], onDelete: SetNull)
  proforma        Proforma?          @relation(fields: [proformaId], references: [id], onDelete: SetNull)
  fournisseur     Fournisseur        @relation(fields: [fournisseurId], references: [id], onDelete: Cascade)
  lignes          LigneCommande[]
  validationLogs  BonCommandeValidationLog[]

  @@map("bons_commande")
  @@index([enterpriseId])
}

model BonCommandeValidationLog {
  id             String            @id @default(uuid())
  bonCommandeId  String
  action         String
  fromStatus     StatusBonCommande
  toStatus       StatusBonCommande
  createdAt      DateTime          @default(now())
  createdById    String?

  bonCommande    BonCommande       @relation(fields: [bonCommandeId], references: [id], onDelete: Cascade)

  @@map("bon_commande_validation_logs")
}

model LigneCommande {
  id            String      @id @default(uuid())
  bonCommandeId String
  articleId      String?
  referenceArticle String?
  designation   String
  categorie     String?
  unite         String?
  quantite      Int
  prixUnitaire  Decimal     @db.Decimal(10, 2)
  tva           Decimal     @db.Decimal(5, 2) @default(0) // % de TVA
  montantHT     Decimal     @db.Decimal(12, 2)
  montantTTC    Decimal     @db.Decimal(12, 2)
  montant       Decimal     @db.Decimal(12, 2) // compatibilité legacy, égale à montantTTC
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  
  bonCommande   BonCommande @relation(fields: [bonCommandeId], references: [id], onDelete: Cascade)

  @@map("lignes_commande")
}

model LigneDemandeAchat {
  id             String       @id @default(uuid())
  demandeAchatId String
  articleId      String?
  referenceArticle String?
  designation    String
  categorie      String?
  unite          String?
  quantite       Int
  prixUnitaire   Decimal      @db.Decimal(10, 2)
  tva            Decimal      @db.Decimal(5, 2) @default(0)
  montantHT      Decimal      @db.Decimal(12, 2)
  montantTTC     Decimal      @db.Decimal(12, 2)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  demandeAchat   DemandeAchat @relation(fields: [demandeAchatId], references: [id], onDelete: Cascade)

  @@map("lignes_demande_achat")
}

model Proforma {
  id                    String               @id @default(uuid())
  numeroProforma        String               @unique
  demandeAchatId        String
  fournisseurId         String
  titre                 String?
  devise                String               @default("XOF")
  montantHT             Decimal              @default(0) @db.Decimal(12, 2)
  montantTVA            Decimal              @default(0) @db.Decimal(12, 2)
  montantTTC            Decimal              @default(0) @db.Decimal(12, 2)
  delaiLivraisonJours   Int?
  disponibilite         String?
  observationsAchat     String?
  committeeProfileCode  String?
  committeeEvaluation   Json?
  committeeDecision     String?
  committeeDecisionNote String?
  committeeEvaluatedAt  DateTime?
  committeeEvaluatedByUserId String?
  committeeEvaluatedByEmail String?
  committeeEvaluatedByServiceId Int?
  committeeEvaluatedByServiceName String?
  committeeSignedAt     DateTime?
  committeeSignedByUserId String?
  committeeSignedByEmail String?
  committeeSignedByServiceId Int?
  committeeSignedByServiceName String?
  status                StatusProforma       @default(BROUILLON)
  notes                 String?
  submittedAt           DateTime?
  approvedAt            DateTime?
  approvedByUserId      String?
  approvedByServiceId   Int?
  approvedByServiceName String?
  rejectionReason       String?
  selectedForOrder      Boolean              @default(false)
  recommendedForApproval Boolean             @default(false)
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  demandeAchat          DemandeAchat         @relation(fields: [demandeAchatId], references: [id], onDelete: Cascade)
  fournisseur           Fournisseur          @relation(fields: [fournisseurId], references: [id], onDelete: Cascade)
  lignes                LigneProforma[]
  approvalLogs          ProformaApprovalLog[]
  bonCommande           BonCommande?

  @@index([demandeAchatId])
  @@index([fournisseurId])
  @@map("proformas")
}

model LigneProforma {
  id              String    @id @default(uuid())
  proformaId      String
  articleId       String?
  referenceArticle String?
  designation     String
  categorie       String?
  unite           String?
  quantite        Int
  prixUnitaire    Decimal   @db.Decimal(10, 2)
  tva             Decimal   @db.Decimal(5, 2) @default(0)
  montantHT       Decimal   @db.Decimal(12, 2)
  montantTTC      Decimal   @db.Decimal(12, 2)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  proforma        Proforma  @relation(fields: [proformaId], references: [id], onDelete: Cascade)

  @@index([proformaId])
  @@map("lignes_proforma")
}

model ProformaApprovalLog {
  id               String         @id @default(uuid())
  proformaId       String
  action           String
  fromStatus       StatusProforma
  toStatus         StatusProforma
  actorUserId      String?
  actorEmail       String?
  actorServiceId   Int?
  actorServiceName String?
  commentaire      String?
  createdAt        DateTime       @default(now())

  proforma         Proforma       @relation(fields: [proformaId], references: [id], onDelete: Cascade)

  @@index([proformaId])
  @@map("proforma_approval_logs")
}

model DemandeAchatApprovalLog {
  id               String             @id @default(uuid())
  demandeAchatId   String
  action           String
  fromStatus       StatusDemandeAchat
  toStatus         StatusDemandeAchat
  actorUserId      String?
  actorEmail       String?
  actorServiceId   Int?
  actorServiceName String?
  commentaire      String?
  createdAt        DateTime           @default(now())

  demandeAchat     DemandeAchat       @relation(fields: [demandeAchatId], references: [id], onDelete: Cascade)

  @@map("demande_achat_approval_logs")
}

model ProcurementOutboxEvent {
  id             String   @id @default(uuid())
  eventType      String
  aggregateType  String
  aggregateId    String
  correlationId  String?
  payload        Json
  status         String   @default("PENDING")
  attempts       Int      @default(0)
  nextAttemptAt  DateTime @default(now())
  lastError      String?
  publishedAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status, nextAttemptAt])
  @@index([aggregateType, aggregateId])
  @@map("procurement_outbox_events")
}
