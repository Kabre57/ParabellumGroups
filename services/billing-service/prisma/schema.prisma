generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Facture {
  id             String          @id @default(uuid())
  numeroFacture  String          @unique
  clientId       String
  serviceId      String?
  serviceName    String?
  serviceLogoUrl String?
  dateEmission   DateTime        @default(now())
  dateEcheance   DateTime
  montantHT      Float
  montantTVA     Float
  montantTTC     Float
  status         FactureStatus   @default(BROUILLON)
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  lignes         LigneFacture[]
  paiements      Paiement[]
  avoirs         Avoir[]

  @@index([clientId])
  @@index([status])
  @@index([dateEmission])
  @@map("factures")
}

model LigneFacture {
  id            String   @id @default(uuid())
  factureId     String
  description   String
  imageUrl      String?
  quantite      Float
  prixUnitaire  Float
  tauxTVA       Float
  montantHT     Float
  montantTVA    Float
  montantTTC    Float
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  facture       Facture  @relation(fields: [factureId], references: [id], onDelete: Cascade)

  @@index([factureId])
  @@map("lignes_facture")
}

model Paiement {
  id               String          @id @default(uuid())
  factureId        String
  montant          Float
  datePaiement     DateTime        @default(now())
  methodePaiement  MethodePaiement
  treasuryAccountId String?
  reference        String?
  notes            String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  facture          Facture         @relation(fields: [factureId], references: [id], onDelete: Cascade)
  treasuryAccount  TreasuryAccount? @relation(fields: [treasuryAccountId], references: [id])

  @@index([factureId])
  @@index([datePaiement])
  @@index([treasuryAccountId])
  @@map("paiements")
}

model Avoir {
  id               String       @id @default(uuid())
  numeroAvoir      String       @unique
  factureId        String
  factureNumero    String
  clientId         String
  serviceId        String?
  serviceName      String?
  serviceLogoUrl   String?
  motif            String
  notes            String?
  montantHT        Float
  montantTVA       Float
  montantTTC       Float
  status           AvoirStatus  @default(BROUILLON)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  facture          Facture      @relation(fields: [factureId], references: [id], onDelete: Cascade)
  lignes           LigneAvoir[]

  @@index([factureId])
  @@index([clientId])
  @@index([status])
  @@index([createdAt])
  @@map("avoirs")
}

model LigneAvoir {
  id            String   @id @default(uuid())
  avoirId       String
  description   String
  quantite      Float
  prixUnitaire  Float
  tauxTVA       Float
  montantHT     Float
  montantTVA    Float
  montantTTC    Float
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  avoir         Avoir    @relation(fields: [avoirId], references: [id], onDelete: Cascade)

  @@index([avoirId])
  @@map("lignes_avoir")
}

model Devis {
  id            String       @id @default(uuid())
  numeroDevis   String       @unique
  clientId      String
  objet         String?
  notes         String?
  serviceId     String?
  serviceName   String?
  serviceLogoUrl String?
  commercialId  String?
  commercialName String?
  commercialEmail String?
  prospectId    String?
  opportuniteId String?
  dateEmission  DateTime     @default(now())
  dateValidite  DateTime
  montantHT     Float
  montantTVA    Float
  montantTTC    Float
  status        DevisStatus  @default(BROUILLON)
  sentAt        DateTime?
  clientRespondedAt DateTime?
  clientComment String?
  revisionNumber Int         @default(1)
  clientAccessToken String?  @unique
  clientAccessTokenExpiresAt DateTime?
  forwardedToBillingAt DateTime?
  forwardedToBillingBy String?
  convertedInvoiceId String?
  convertedInvoiceNumber String?
  acceptedAt    DateTime?
  refusedAt     DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  lignes        LigneDevis[]
  evenements    DevisEvent[]

  @@index([clientId])
  @@index([prospectId])
  @@index([opportuniteId])
  @@index([status])
  @@index([dateEmission])
  @@map("devis")
}

model LigneDevis {
  id            String   @id @default(uuid())
  devisId       String
  description   String
  imageUrl      String?
  quantite      Float
  prixUnitaire  Float
  tauxTVA       Float
  montantHT     Float
  montantTVA    Float
  montantTTC    Float
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  devis         Devis    @relation(fields: [devisId], references: [id], onDelete: Cascade)

  @@index([devisId])
  @@map("lignes_devis")
}

model DevisEvent {
  id          String   @id @default(uuid())
  devisId     String
  type        String
  actorId     String?
  actorEmail  String?
  actorRole   String?
  note        String?
  payload     Json?
  createdAt   DateTime @default(now())

  devis       Devis    @relation(fields: [devisId], references: [id], onDelete: Cascade)

  @@index([devisId])
  @@index([type])
  @@index([createdAt])
  @@map("devis_events")
}

model PurchaseCommitment {
  id             String   @id @default(uuid())
  sourceType     String
  sourceId       String
  sourceNumber   String
  serviceId      Int?
  serviceName    String?
  supplierId     String?
  supplierName   String?
  amountHT       Float
  amountTVA      Float
  amountTTC      Float
  currency       String   @default("XOF")
  status         PurchaseCommitmentStatus @default(ENGAGE)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  factureFournisseurId String?
  factureFournisseur   FactureFournisseur? @relation(fields: [factureFournisseurId], references: [id])
  decaissements        Decaissement[]

  @@unique([sourceType, sourceId])
  @@index([status])
  @@map("purchase_commitments")
}

model FactureFournisseur {
  id             String   @id @default(uuid())
  numeroFacture  String   @unique
  fournisseurId  String?
  fournisseurNom String?
  dateFacture    DateTime @default(now())
  dateEcheance   DateTime?
  montantHT      Float
  montantTVA     Float
  montantTTC     Float
  currency       String   @default("XOF")
  status         String   @default("A_PAYER") // A_PAYER, PARTIELLEMENT_PAYEE, PAYEE, ANNULEE
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  commitmentId   String?
  commitment     PurchaseCommitment[]
  decaissements  Decaissement[]

  @@index([fournisseurId])
  @@index([status])
  @@map("factures_fournisseurs")
}

model Encaissement {
  id                String   @id @default(uuid())
  numeroPiece       String   @unique
  clientId          String?
  clientName        String
  description       String
  amountHT          Float    @default(0)
  amountTVA         Float    @default(0)
  amountTTC         Float
  currency          String   @default("XOF")
  paymentMethod     MethodePaiement
  treasuryAccountId String?
  dateEncaissement  DateTime @default(now())
  reference         String?
  notes             String?
  createdByUserId   String?
  createdByEmail    String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  treasuryAccount   TreasuryAccount? @relation(fields: [treasuryAccountId], references: [id])
  factureClientId   String?

  @@index([dateEncaissement])
  @@index([treasuryAccountId])
  @@map("encaissements")
}

model Decaissement {
  id                String   @id @default(uuid())
  numeroPiece       String   @unique
  beneficiaryName   String
  description       String
  amountHT          Float    @default(0)
  amountTVA         Float    @default(0)
  amountTTC         Float
  currency          String   @default("XOF")
  paymentMethod     MethodePaiement
  treasuryAccountId String?
  dateDecaissement  DateTime @default(now())
  reference         String?
  notes             String?
  status            String   @default("VALIDE") // VALIDE, DECAISSE, ANNULE
  createdByUserId   String?
  createdByEmail    String?
  approvedByUserId  String?
  approvedByEmail   String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  treasuryAccount      TreasuryAccount? @relation(fields: [treasuryAccountId], references: [id])
  factureFournisseurId String?
  factureFournisseur   FactureFournisseur? @relation(fields: [factureFournisseurId], references: [id])
  commitmentId         String?
  commitment           PurchaseCommitment? @relation(fields: [commitmentId], references: [id])

  @@index([dateDecaissement])
  @@index([treasuryAccountId])
  @@map("decaissements")
}

model TreasuryAccount {
  id              String               @id @default(uuid())
  name            String
  type            TreasuryAccountType
  bankName        String?
  accountNumber   String?
  currency        String               @default("XOF")
  openingBalance  Float                @default(0)
  currentBalance  Float                @default(0)
  isDefault       Boolean              @default(false)
  isActive        Boolean              @default(true)
  createdByUserId String?
  createdByEmail  String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  payments        Paiement[]
  encaissements   Encaissement[]
  decaissements   Decaissement[]
  closures        TreasuryClosure[]

  @@index([type])
  @@index([isActive])
  @@map("treasury_accounts")
}

model TreasuryClosure {
  id                 String                @id @default(uuid())
  treasuryAccountId  String?
  periodType         TreasuryClosurePeriod
  periodLabel        String?
  periodStart        DateTime
  periodEnd          DateTime
  expectedCash       Float                 @default(0)
  expectedCheque     Float                 @default(0)
  expectedCard       Float                 @default(0)
  expectedOther      Float                 @default(0)
  expectedTotal      Float                 @default(0)
  countedCash        Float                 @default(0)
  countedCheque      Float                 @default(0)
  countedCard        Float                 @default(0)
  countedOther       Float                 @default(0)
  countedTotal       Float                 @default(0)
  ticketZ            Float                 @default(0)
  variance           Float                 @default(0)
  status             TreasuryClosureStatus @default(DRAFT)
  notes              String?
  createdByUserId    String?
  createdByEmail     String?
  validatedByUserId  String?
  validatedByEmail   String?
  closedAt           DateTime?
  validatedAt        DateTime?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  treasuryAccount TreasuryAccount? @relation(fields: [treasuryAccountId], references: [id])

  @@index([periodStart])
  @@index([periodEnd])
  @@index([treasuryAccountId])
  @@map("treasury_closures")
}

model BillingProcessedEvent {
  id           String   @id @default(uuid())
  eventId      String   @unique
  eventType    String
  source       String
  processedAt  DateTime @default(now())

  @@index([eventType])
  @@map("billing_processed_events")
}

model AccountingAccount {
  id              String                @id @default(uuid())
  code            String                @unique
  label           String
  type            AccountingAccountType
  description     String?
  isSystem        Boolean               @default(false)
  isActive        Boolean               @default(true)
  openingBalance  Float                 @default(0)
  currentBalance  Float                 @default(0)
  createdByUserId String?
  createdByEmail  String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  journalLines    AccountingJournalLine[]

  @@index([type])
  @@index([isActive])
  @@map("accounting_accounts")
}

model AccountingJournalEntry {
  id              String                  @id @default(uuid())
  entryNumber     String                  @unique
  entryDate       DateTime                @default(now())
  journalCode     String
  journalLabel    String
  label           String
  reference       String?
  sourceType      String?
  sourceId        String?
  createdByUserId String?
  createdByEmail  String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  lines           AccountingJournalLine[]

  @@index([entryDate])
  @@index([journalCode])
  @@map("accounting_journal_entries")
}

model AccountingJournalLine {
  id          String                 @id @default(uuid())
  entryId     String
  accountId   String
  side        AccountingEntrySide
  amount      Float
  description String?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  entry       AccountingJournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  account     AccountingAccount      @relation(fields: [accountId], references: [id], onDelete: Restrict)

  @@index([entryId])
  @@index([accountId])
  @@index([side])
  @@map("accounting_journal_lines")
}

enum FactureStatus {
  BROUILLON
  EMISE
  PAYEE
  EN_RETARD
  ANNULEE
}

enum DevisStatus {
  BROUILLON
  ENVOYE
  MODIFICATION_DEMANDEE
  ACCEPTE
  REFUSE
  EXPIRE
  TRANSMIS_FACTURATION
  FACTURE
}

enum MethodePaiement {
  VIREMENT
  CHEQUE
  CARTE
  ESPECES
}

enum PurchaseCommitmentStatus {
  ENGAGE
  LIQUIDE
  ORDONNANCE
  PAYE
}

enum TreasuryClosureStatus {
  DRAFT
  CLOSED
  VALIDATED
}

enum TreasuryClosurePeriod {
  MONTH
  QUARTER
  YEAR
  CUSTOM
}

enum TreasuryAccountType {
  BANK
  CASH
}

enum AvoirStatus {
  BROUILLON
  EMISE
  APPLIQUE
  ANNULE
}

enum AccountingAccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum AccountingEntrySide {
  DEBIT
  CREDIT
}
