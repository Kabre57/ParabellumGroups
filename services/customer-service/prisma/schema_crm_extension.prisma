// ==================== NOUVEAUX MODULES CRM (Phase 1) ====================
// Ce fichier est annexé au schema.prisma principal.
// Exécuter: node scripts/append-crm-schema.js

enum CanalConsent {
  EMAIL
  SMS
  WHATSAPP
  TELEPHONE
  COURRIER
  PUSH
}

enum FinaliteConsent {
  MARKETING
  NEWSLETTER
  RELANCE
  SONDAGE
  STATISTIQUES
  PARTAGE_PARTENAIRES
}

enum TypeSegmentCRM {
  DYNAMIQUE
  STATIQUE
  HYBRIDE
}

enum StatutTicket {
  NOUVEAU
  EN_COURS
  EN_ATTENTE
  RESOLU
  FERME
}

enum PrioriteTicket {
  BASSE
  NORMALE
  HAUTE
  URGENTE
}

enum CategorieTicket {
  RECLAMATION
  DEMANDE
  INFORMATION
  INCIDENT
  SUGGESTION
}

enum CanalTicket {
  EMAIL_CANAL
  TELEPHONE
  PORTAIL
  COURRIER
  WHATSAPP
  EN_PERSONNE
}

enum TypeSondage {
  NPS
  CSAT
  CES
  PERSONNALISE
}

enum StatutSondage {
  BROUILLON
  ACTIF
  PAUSE
  FERME
}

enum CategorieNPS {
  PROMOTEUR
  PASSIF
  DETRACTEUR
}

enum CanalRelance {
  EMAIL_RELANCE
  SMS
  WHATSAPP
}

enum DeclencheurRelance {
  TICKET_OUVERT
  ECHEANCE_CONTRAT
  SANS_INTERACTION
  SONDAGE_NON_REPONDU
  COTISATION
  ANNIVERSAIRE
  MANUEL
}

// Consentements RGPD granulaires par canal et finalité
model ConsentementClient {
  id                 String          @id @default(uuid())
  clientId           String
  canal              CanalConsent
  finalite           FinaliteConsent
  consenti           Boolean         @default(false)
  dateConsent        DateTime?       @default(now())
  dateRevocation     DateTime?
  sourceConsent      String?
  sourceUrl          String?
  ipAddress          String?
  preuveConsentement String?
  notes              String?

  client             Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)

  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@map("consentements_client")
  @@unique([clientId, canal, finalite])
  @@index([clientId])
  @@index([canal])
  @@index([finalite])
  @@index([consenti])
}

// Segments clients (segmentation dynamique multicritères)
model SegmentClient {
  id            String             @id @default(uuid())
  nom           String
  description   String?
  couleur       String?            @default("#3B82F6")
  criteres      Json               @default("{}")
  typeSegment   TypeSegmentCRM     @default(DYNAMIQUE)
  isActive      Boolean            @default(true)
  isSystem      Boolean            @default(false)
  compte        Int                @default(0)
  dernierCalcul DateTime?
  tags          String[]           @default([])
  createdById   String

  membres       SegmentClientMembre[]
  sondages      SondageSatisfaction[]
  relances      RelanceAutomatique[]

  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@map("segments_clients")
  @@index([isActive])
  @@index([typeSegment])
}

// Liaison segment-client (pour segments statiques)
model SegmentClientMembre {
  id          String        @id @default(uuid())
  segmentId   String
  clientId    String
  ajouteLe    DateTime      @default(now())
  ajouteById  String?
  source      String        @default("MANUEL")
  exclure     Boolean       @default(false)

  segment     SegmentClient @relation(fields: [segmentId], references: [id], onDelete: Cascade)
  client      Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("segment_clients_membres")
  @@unique([segmentId, clientId])
  @@index([clientId])
  @@index([segmentId])
}

// Tickets et Réclamations CRM
model TicketCRM {
  id                  String          @id @default(uuid())
  reference           String?         @unique
  clientId            String
  contactId           String?
  sujet               String
  description         String
  categorie           CategorieTicket @default(DEMANDE)
  canal               CanalTicket     @default(EMAIL_CANAL)
  statut              StatutTicket    @default(NOUVEAU)
  priorite            PrioriteTicket  @default(NORMALE)
  assigneA            String?
  serviceId           String?
  slaDeadline         DateTime?
  premierTraitementLe DateTime?
  resolvedAt          DateTime?
  closedAt            DateTime?
  satisfactionScore   Int?
  satisfactionComment String?
  tags                String[]        @default([])
  metadata            Json?           @default("{}")
  createdById         String

  client              Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  contact             Contact?        @relation(fields: [contactId], references: [id])
  historiqueTicket    TicketHistorique[]
  reponsesSatisfaction ReponseSondage[]

  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@map("tickets_crm")
  @@index([clientId])
  @@index([statut])
  @@index([priorite])
  @@index([assigneA])
  @@index([slaDeadline])
  @@index([createdAt])
  @@index([categorie])
}

// Historique des tickets
model TicketHistorique {
  id             String    @id @default(uuid())
  ticketId       String
  typeEvenement  String
  ancienneValeur String?
  nouvelleValeur String?
  commentaire    String?
  isPublic       Boolean   @default(false)
  auteurId       String

  ticket         TicketCRM @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  createdAt      DateTime  @default(now())

  @@map("tickets_historique")
  @@index([ticketId])
  @@index([createdAt])
}

// Sondages de satisfaction (NPS, CSAT, CES)
model SondageSatisfaction {
  id              String          @id @default(uuid())
  titre           String
  description     String?
  typeSondage     TypeSondage     @default(NPS)
  statut          StatutSondage   @default(BROUILLON)
  declencheur     String          @default("MANUEL")
  delaiEnvoiJours Int             @default(1)
  questions       Json            @default("[]")
  segmentId       String?
  dateDebut       DateTime?
  dateFin         DateTime?
  nombreEnvois    Int             @default(0)
  nombreReponses  Int             @default(0)
  scoreNPS        Float?
  scoreMoyen      Float?
  createdById     String

  segment         SegmentClient?  @relation(fields: [segmentId], references: [id])
  reponses        ReponseSondage[]

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@map("sondages_satisfaction")
  @@index([statut])
  @@index([typeSondage])
  @@index([segmentId])
}

// Réponses aux sondages
model ReponseSondage {
  id           String              @id @default(uuid())
  sondageId    String
  clientId     String
  contactId    String?
  ticketId     String?
  reponses     Json                @default("{}")
  scoreGlobal  Float?
  scoreNPS     Int?
  categorieNPS CategorieNPS?
  commentaire  String?
  tokenAcces   String?             @unique
  envoiLe      DateTime            @default(now())
  reponseLe    DateTime?

  sondage      SondageSatisfaction @relation(fields: [sondageId], references: [id], onDelete: Cascade)
  client       Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  contact      Contact?            @relation(fields: [contactId], references: [id])
  ticket       TicketCRM?          @relation(fields: [ticketId], references: [id])

  createdAt    DateTime            @default(now())

  @@map("reponses_sondage")
  @@index([sondageId])
  @@index([clientId])
  @@index([tokenAcces])
}

// Relances automatiques programmables
model RelanceAutomatique {
  id                 String              @id @default(uuid())
  nom                String
  description        String?
  declencheur        DeclencheurRelance
  delaiJours         Int                 @default(7)
  canal              CanalRelance        @default(EMAIL_RELANCE)
  templateId         String?
  sujetTemplate      String?
  corpsTemplate      String?
  segmentId          String?
  conditions         Json?               @default("{}")
  estActif           Boolean             @default(true)
  heureEnvoi         String              @default("09:00")
  joursEnvoi         String[]            @default(["LUNDI","MARDI","MERCREDI","JEUDI","VENDREDI"])
  nombreExecutions   Int                 @default(0)
  dernierExecutionLe DateTime?
  createdById        String

  segment            SegmentClient?      @relation(fields: [segmentId], references: [id])
  executions         RelanceExecution[]

  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@map("relances_automatiques")
  @@index([estActif])
  @@index([declencheur])
  @@index([canal])
}

// Exécutions des relances
model RelanceExecution {
  id        String             @id @default(uuid())
  relanceId String
  clientId  String
  canal     String
  statut    String             @default("ENVOYE")
  messageId String?
  ouvertLe  DateTime?
  reponseLe DateTime?
  erreur    String?
  metadata  Json?              @default("{}")

  relance   RelanceAutomatique @relation(fields: [relanceId], references: [id], onDelete: Cascade)
  client    Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)

  createdAt DateTime           @default(now())

  @@map("relances_executions")
  @@index([relanceId])
  @@index([clientId])
  @@index([statut])
}
