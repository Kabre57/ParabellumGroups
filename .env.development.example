# Parabellum ERP - Development environment template (local clone)
# Usage:
#   cp .env.development.example .env
#   docker compose up --build

NODE_ENV=development

# Core secrets
JWT_SECRET=replace-with-a-long-random-dev-jwt-secret

# PostgreSQL
DB_USER=postgres
DB_PASSWORD=replace-with-a-strong-dev-db-password
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-a-strong-dev-db-password
POSTGRES_DB=parabellum

# Redis
REDIS_PASSWORD=replace-with-a-strong-dev-redis-password

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=replace-with-a-strong-dev-minio-password
