# Parabellum Groups - Generic environment template
# Prefer one of these:
#   cp .env.production.example .env   # VPS / production-like setup
#   cp .env.development.example .env  # local development setup

# JWT Secret (shared by auth-related services)
JWT_SECRET=replace-with-a-long-random-secret

# Database (PostgreSQL container + services)
DB_USER=postgres
DB_PASSWORD=replace-with-a-strong-database-password
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-a-strong-database-password
POSTGRES_DB=parabellum

# Redis
REDIS_PASSWORD=replace-with-a-strong-redis-password

# MinIO (S3 compatible)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=replace-with-a-strong-minio-password
