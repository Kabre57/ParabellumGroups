# Parabellum ERP - Production environment template (VPS)
# Usage:
#   cp .env.production.example .env
#   edit every placeholder before running docker compose

NODE_ENV=production

# Core secrets
JWT_SECRET=replace-with-a-long-random-production-jwt-secret

# PostgreSQL
DB_USER=postgres
DB_PASSWORD=replace-with-a-very-strong-production-db-password
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-a-very-strong-production-db-password
POSTGRES_DB=parabellum

# Redis
REDIS_PASSWORD=replace-with-a-very-strong-production-redis-password

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=replace-with-a-very-strong-production-minio-password
